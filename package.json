{
  "name": "khronos-maps",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "db:migrate": "tsx --env-file=.env.local src/lib/db/migrate.ts",
    "db:generate": "tsx --env-file=.env.local node_modules/drizzle-kit/bin.cjs generate --config=drizzle.config.ts",
    "db:seed": "tsx --env-file=.env.local src/lib/db/seed.ts",
    "scrape:rockthesport": "tsx --env-file=.env.local scripts/scrape-rts.ts",
    "geocode": "tsx --env-file=.env.local scripts/geocode-events.ts"
  },
  "dependencies": {
    "@libsql/client": "^0.17.0",
    "cheerio": "^1.2.0",
    "drizzle-orm": "^0.45.1",
    "framer-motion": "^12.34.3",
    "leaflet": "^1.9.4",
    "next": "16.1.6",
    "next-intl": "^4.8.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-leaflet": "^5.0.0",
    "react-leaflet-cluster": "^4.0.0",
    "use-debounce": "^10.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.9",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
